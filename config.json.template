{
  "compartment_id": "ocid1.compartment.oc1..your-compartment-id",
  "endpoint": "https://inference.generativeai.us-chicago-1.oci.oraclecloud.com",
  "model_aliases": {
    "claude-haiku-4-5": "xai.grok-4-fast-non-reasoning",
    "claude-3-5-sonnet": "xai.grok-4-fast-non-reasoning",
    "claude-3-haiku": "xai.grok-4-fast-non-reasoning"
  },
  "model_definitions": {
    "xai.grok-4-fast-non-reasoning": {
      "ocid": "ocid1.generativeaimodel.oc1.us-chicago-1.your-model-ocid",
      "model_types": ["text"],
      "max_tokens_key": "max_tokens",
      "temperature": 0.7
    },
    "xai.grok-4-fast-reasoning": {
      "ocid": "ocid1.generativeaimodel.oc1.us-chicago-1.your-model-ocid",
      "model_types": ["text"],
      "max_tokens_key": "max_tokens",
      "temperature": 0.7
    },
    "xai.grok-code-fast-1": {
      "ocid": "ocid1.generativeaimodel.oc1.us-chicago-1.your-model-ocid",
      "model_types": ["text"],
      "max_tokens_key": "max_tokens",
      "temperature": 0.7
    },
    "openai.gpt-oss-20b": {
      "ocid": "ocid1.generativeaimodel.oc1.us-chicago-1.your-model-ocid",
      "model_types": ["text"],
      "max_tokens_key": "max_completion_tokens",
      "temperature": 0.7
    },
    "openai.gpt-oss-120b": {
      "ocid": "ocid1.generativeaimodel.oc1.us-chicago-1.your-model-ocid",
      "model_types": ["text"],
      "max_tokens_key": "max_completion_tokens",
      "temperature": 0.7
    },
    "openai.gpt-5": {
      "ocid": "ocid1.generativeaimodel.oc1.us-chicago-1.your-model-ocid",
      "model_types": ["text"],
      "max_tokens_key": "max_completion_tokens",
      "temperature": 1.0
    },
    "cohere.command-r-plus": {
        "ocid": "ocid1.generativeaimodel.oc1...",
        "model_types": ["text"],
        "api_format": "cohere",
        "max_tokens_key": "max_tokens",
        "temperature": 0.7
    },
    "cohere.command-r": {
        "ocid": "ocid1.generativeaimodel.oc1...",
        "model_types": ["text"],
        "api_format": "cohere",
        "max_tokens_key": "max_tokens",
        "temperature": 0.7
    },
    "google.gemini-2.5-pro": {
      "ocid": "ocid1.generativeaimodel.oc1...",
      "model_types": ["text", "images", "video"],
      "max_tokens_key": "max_completion_tokens",
      "temperature": 1.0
    }
  },
  "default_model": "openai.gpt-oss-20b",
  "debug": false,
  "debug_redact_media": true,
  "enable_nl_tool_fallback": false,
  "messages_max_items": 200,
  "rate_limit": {
    "enabled": false,
    "requests": 60,
    "window_sec": 60
  },
  "debug_ui": {
    "enabled": false,
    "dump_dir": "debug_dumps",
    "index_db": "debug_dumps/index.db",
    "scan_interval_sec": 3,
    "auth_mode": "bearer",
    "max_detail_bytes": 2000000
  },
  "guardrails": {
    "enabled": false,
    "mode": "block",
    "default_language": "en",
    "config_dir": "guardrails",
    "block_http_status": 400,
    "block_message": "Request blocked by guardrails policy.",
    "streaming_behavior": "reject",
    "log_details": false,
    "redact_logs": true,
    "input": {
      "enabled": true,
      "fail_mode": "closed",
      "include_system": false,
      "include_tool_results": true,
      "content_moderation": {
        "enabled": true,
        "categories": ["OVERALL"]
      },
      "prompt_injection": {
        "enabled": true,
        "threshold": 0.95
      },
      "pii": {
        "enabled": false,
        "types": ["EMAIL", "PERSON", "TELEPHONE_NUMBER"]
      },
      "local_blocklist": {
        "enabled": false,
        "file": "blocklist.txt"
      }
    },
    "output": {
      "enabled": false,
      "fail_mode": "open",
      "content_moderation": {
        "enabled": true,
        "categories": ["OVERALL"]
      },
      "pii": {
        "enabled": false,
        "types": ["EMAIL", "PERSON", "TELEPHONE_NUMBER"],
        "action": "redact",
        "placeholder": "[REDACTED]"
      }
    }
  },
  "server": {
    "host": "127.0.0.1",
    "port": 8000,
    "log_level": "warning"
  }
}
